generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User {
  id               String        @id @default(cuid())
  email            String        @unique
  password         String
  name             String?
  role             String        @default("USER") // USER, STAFF, ADMIN
  suspendedAt      DateTime?
  suspensionReason String?
  isMuted          Boolean       @default(false)
  muteExpiresAt    DateTime?
  isRestricted     Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  favorites        Favorite[]
  watchHistory     WatchHistory[]
  settings         UserSettings?
  comments         Comment[]
  tickets          Ticket[]
  shortcuts        CustomShortcut[]
}

model Favorite {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  channelId String
  createdAt DateTime @default(now())

  @@unique([userId, channelId])
  @@index([userId, channelId])
}

model WatchHistory {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  channelId   String
  channelName String
  channelLogo String?
  watchedAt   DateTime @default(now())

  @@index([userId, watchedAt])
}

model UserSettings {
  id              String   @id @default(cuid())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String   @unique
  accentColor     String   @default("cyan")
  playerLayout    String   @default("theater")
  defaultVolume   Float    @default(1.0)
  autoplay        Boolean  @default(false)
  performanceMode Boolean  @default(false)
  language        String   @default("en")
  darkMode        Boolean  @default(true)
  showEpg         Boolean  @default(true)
  updatedAt       DateTime @updatedAt
}

model CustomShortcut {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  action    String   // toggle_fullscreen, toggle_mute, next_channel, prev_channel, toggle_play, screenshot, theater_mode
  key       String   // e.g. "f", "m", "ArrowRight"
  
  @@unique([userId, action])
}

model Comment {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  channelId String
  text      String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([channelId, createdAt])
}

model Ticket {
  id          String    @id @default(cuid())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  subject     String
  message     String
  type        String    @default("SUPPORT") // SUPPORT, APPEAL
  status      String    @default("OPEN")    // OPEN, IN_PROGRESS, CLOSED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Incident {
  id          String    @id @default(cuid())
  title       String
  description String
  status      String    @default("INVESTIGATING") // INVESTIGATING, IDENTIFIED, MONITORING, RESOLVED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  resolvedAt  DateTime?
}
