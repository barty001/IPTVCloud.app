generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User {
  id                String           @id @default(cuid())
  email             String           @unique
  username          String?          @unique
  password          String
  name              String?
  role              String           @default("USER") // USER, MODERATOR, STAFF, ADMIN
  suspendedAt       DateTime?
  suspensionReason  String?
  isMuted           Boolean          @default(false)
  muteExpiresAt     DateTime?
  isRestricted      Boolean          @default(false)
  isVerified        Boolean          @default(false)
  verifiedAt        DateTime?
  twoFactorSecret   String?
  twoFactorEnabled  Boolean          @default(false)
  lastUsernameChange DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  favorites         Favorite[]
  watchHistory      WatchHistory[]
  settings          UserSettings?
  comments          Comment[]
  tickets           Ticket[]         @relation("UserTickets")
  handledTickets    Ticket[]         @relation("AdminTickets")
  shortcuts         CustomShortcut[]
  posts             Post[]
  postComments      PostComment[]
  postLikes         PostLike[]
}

model Favorite {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  channelId String
  createdAt DateTime @default(now())

  @@unique([userId, channelId])
  @@index([userId, channelId])
}

model WatchHistory {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  channelId   String
  channelName String
  channelLogo String?
  category    String?
  country     String?
  watchedAt   DateTime @default(now())

  @@index([userId, watchedAt])
}

model UserSettings {
  id              String   @id @default(cuid())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String   @unique
  accentColor     String   @default("cyan")
  playerLayout    String   @default("theater")
  defaultVolume   Float    @default(1.0)
  autoplay        Boolean  @default(false)
  performanceMode Boolean  @default(false)
  language        String   @default("en")
  darkMode        Boolean  @default(true)
  showEpg         Boolean  @default(true)
  updatedAt       DateTime @updatedAt
}

model CustomShortcut {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  action String // toggle_fullscreen, toggle_mute, next_channel, prev_channel, toggle_play, screenshot, theater_mode
  key    String // e.g. "f", "m", "ArrowRight"

  @@unique([userId, action])
}

model Comment {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  channelId String
  text      String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([channelId, createdAt])
}

model Ticket {
  id          String           @id @default(cuid())
  user        User             @relation("UserTickets", fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  handledBy   User?            @relation("AdminTickets", fields: [handledById], references: [id])
  handledById String?
  subject     String
  message     String
  type        String           @default("SUPPORT") // SUPPORT, APPEAL, BUG, FEATURE
  status      String           @default("OPEN") // OPEN, IN_PROGRESS, HANDLED, CLOSED, NOT_PLANNED, INVALID
  isArchived  Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  responses   TicketResponse[]
}

model TicketResponse {
  id        String   @id @default(cuid())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId  String
  userId    String
  message   String
  createdAt DateTime @default(now())
}

model Incident {
  id          String           @id @default(cuid())
  title       String
  description String
  tags        String[]         @default([])
  status      String           @default("INVESTIGATING") // INVESTIGATING, IDENTIFIED, MONITORING, RESOLVED
  severity    String           @default("LOW") // LOW, MEDIUM, HIGH, CRITICAL
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  resolvedAt  DateTime?
  updates     IncidentUpdate[]
}

model IncidentUpdate {
  id          String   @id @default(cuid())
  incident    Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  incidentId  String
  message     String
  status      String
  createdAt   DateTime @default(now())
}

model Post {
  id        String        @id @default(cuid())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  title     String
  content   String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  comments  PostComment[]
  likes     PostLike[]
}

model PostComment {
  id        String   @id @default(cuid())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PostLike {
  id        String   @id @default(cuid())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model UptimeRecord {
  id        String   @id @default(cuid())
  status    String   // UP, DOWN, DEGRADED
  latency   Int?
  createdAt DateTime @default(now())
}
