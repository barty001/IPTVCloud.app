# Example environment variables for IPTVCloud.app
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# M3U source (override if you have a private feed)
M3U_PRIMARY_URL=https://iptv-org.github.io/iptv/index.m3u
# Cache TTL in seconds (default 600 = 10 minutes)
M3U_CACHE_TTL=600

# Admin API key for protected admin routes
DATABASE_URL=file:./dev.db
JWT_SECRET=changeme

# Admin API key for protected admin routes
ADMIN_API_KEY=changeme
ADMIN_EMAILS=admin@example.com
