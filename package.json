{
  "name": "iptvcloud-app",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/ReinfyTeam/IPTVCloud.app"
  },
  "scripts": {
    "dev": "next dev -p 5000 -H 0.0.0.0",
    "db:dev": "node scripts/toggle-db.js dev && prisma generate",
    "db:prod": "node scripts/toggle-db.js prod && prisma generate",
    "build": "npm run db:prod && next build",
    "start": "next start -p 5000 -H 0.0.0.0",
    "lint": "next lint --fix",
    "format": "prettier --write .",
    "test": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^4.16.2",
    "@upstash/redis": "^1.37.0",
    "axios": "^1.4.0",
    "bcryptjs": "^2.4.3",
    "hls.js": "^1.4.0",
    "jsonwebtoken": "^9.0.0",
    "next": "13.4.8",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "xml2js": "^0.4.23",
    "zustand": "^4.1.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.28",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.45.0",
    "eslint-config-next": "13.4.8",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "prisma": "^4.16.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.2.2",
    "vitest": "^1.4.0"
  }
}
