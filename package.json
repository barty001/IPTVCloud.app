{
  "name": "iptvcloud-app",
  "version": "0.1.0",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/ReinfyTeam/IPTVCloud.app"
  },
  "scripts": {
    "dev": "next dev -p 8080 -H 0.0.0.0",
    "build": "npm run format && npm run type-check && npm run lint && next build",
    "start": "next start -p 8080 -H 0.0.0.0",
    "lint": "eslint . --ignore-pattern next-env.d.ts",
    "format": "prettier --write .",
    "test": "vitest",
    "type-check": "tsc --noEmit",
    "db:verify": "npx ts-node tools/scripts/verify-db.ts",
    "db:update": "npx ts-node tools/scripts/update-schema.ts"
  },
  "dependencies": {
    "@iptv-org/sdk": "^1.3.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/jsdom": "^28.0.1",
    "@types/speakeasy": "^2.0.10",
    "@types/uuid": "^10.0.0",
    "@upstash/redis": "^1.37.0",
    "@vercel/blob": "^2.3.3",
    "@vercel/speed-insights": "^2.0.0",
    "axios": "^1.4.0",
    "bcryptjs": "^2.4.3",
    "hls.js": "^1.4.0",
    "isomorphic-dompurify": "^3.10.0",
    "jsdom": "^29.0.2",
    "jsonwebtoken": "^9.0.0",
    "next": "^16.2.4",
    "nextjs-toploader": "^3.9.17",
    "otplib": "^13.4.0",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "speakeasy": "^2.0.0",
    "undici": "^8.1.0",
    "uuid": "^14.0.0",
    "xml2js": "^0.6.2",
    "zod": "^4.3.6",
    "zustand": "^4.1.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/dotenv": "^6.1.1",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.2.28",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.4.2",
    "eslint": "^8.45.0",
    "eslint-config-next": "13.4.8",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.2.2",
    "vitest": "^4.1.4"
  }
}
